# Path or libSQL URL for the application database.
#
# Examples:
#   - Local file:  file:./data/loot.db
#   - Turso cloud: libsql://<your-db>.turso.io
#
# Leaving this unset falls back to a local file under data/loot.db, which
# is the recommended choice for self-hosted Docker deployments.
DATABASE_URL=file:./data/loot.db

# Auth token for a remote libSQL/Turso database. Only required when
# DATABASE_URL points at a remote instance.
# DATABASE_AUTH_TOKEN=
